<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS site configuration for this PHP application.
  Prerequisites: PHP installed; FastCGI handler mapped to *.php; MySQL reachable from the server.
  IIS URL Rewrite 2.0 module must be installed for the uploads rule below.

  After first-time DB setup, consider blocking public access to install.php and upgrade_roles.php
  (URL Rewrite rule, IP restriction, or removing those files from production).
-->
<configuration>
  <system.webServer>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.php" />
      </files>
    </defaultDocument>
    <!-- Block direct execution of script-like files under uploads (match is relative to this site or app root). -->
    <rewrite>
      <rules>
        <!--
          Hide :8082: add an IIS site binding for http:80 (same host, same physical path) for faculty_scheduling.wpu.edu.ph,
          then these rules redirect :8082 → default port so the address bar shows http://faculty_scheduling.wpu.edu.ph/...
        -->
        <rule name="Redirect 8082 to HTTPS default port" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{SERVER_PORT}" pattern="^8082$" />
            <add input="{HTTP_HOST}" pattern="^([^:]+)(:8082)?$" />
            <add input="{HTTPS}" pattern="^on$" />
          </conditions>
          <action type="Redirect" url="https://{C:1}/{R:1}" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <rule name="Redirect 8082 to HTTP default port" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{SERVER_PORT}" pattern="^8082$" />
            <add input="{HTTP_HOST}" pattern="^([^:]+)(:8082)?$" />
            <add input="{HTTPS}" pattern="^on$" negate="true" />
          </conditions>
          <action type="Redirect" url="http://{C:1}/{R:1}" appendQueryString="true" redirectType="Permanent" />
        </rule>
        <!--
          HTTP→HTTPS redirect was removed: this server has no https:443 binding or SSL cert (redirect caused "connection refused").
          After binding a certificate to https://faculty_scheduling.safe.wpu.edu.ph in IIS, re-enable a redirect rule here if desired.
          Session cookies already use Secure only when the request is HTTPS (see includes/auth.php).
        -->
        <rule name="Block scripts in uploads" stopProcessing="true">
          <match url="^uploads/.*\.(php|phtml|php5|phar)$" ignoreCase="true" />
          <action type="CustomResponse" statusCode="404" statusReason="Not Found" statusDescription="Not Found" />
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <!-- Align with php.ini upload_max_filesize / post_max_size if you raise this -->
        <requestLimits maxAllowedContentLength="52428800" />
        <!-- Block direct HTTP access to sensitive path segments (PHP includes still work on disk) -->
        <hiddenSegments>
          <add segment="config" />
        </hiddenSegments>
        <denyUrlSequences>
          <add sequence="/install/" />
          <add sequence="/DB/" />
        </denyUrlSequences>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
